# Database
DATABASE_URL=postgresql://liquidark:liquidark@localhost:5433/liquidark

# Web3
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=   # Get from cloud.walletconnect.com
BASE_RPC_URL=https://mainnet.base.org   # Or Alchemy/Infura for better reliability
ALCHEMY_API_KEY=                        # dashboard.alchemy.com — needed for tx history (#52)

# The Graph (for accurate position entry data)
GRAPH_API_KEY=              # Get from thegraph.com/studio (free tier)

# Price APIs (optional — free tier works without keys)
COINGECKO_API_KEY=
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Ingestion (pool data sync)
INGEST_SECRET=              # Secret key for /api/internal/ingest endpoint

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session (REQUIRED — must be a strong random secret, never use the placeholder)
# Generate with: openssl rand -base64 48
SESSION_SECRET=                            # ← REQUIRED: run `openssl rand -base64 48` and paste the output here

# Backend (Railway)
BACKEND_URL=http://localhost:3001          # Railway backend URL
BACKEND_PORT=3001
INGEST_ON_STARTUP=false

# Upstash Redis (rate limiting — strongly recommended in production)
# Sign up free at https://upstash.com → create a Redis database → copy REST credentials
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=                          # ← paste token from Upstash console

# Telegram alerts bot
TELEGRAM_BOT_TOKEN=                        # Create via @BotFather on Telegram
ALERT_INTERVAL_MS=300000                   # Alert check interval (default: 5 min)

# Feature flags (dev / paid environments only)
# Set ENABLE_TIERS=true on dev.liquidarc.app to enforce tier limits.
# On main (liquidarc.app) leave unset — all users get pro-level limits.
ENABLE_TIERS=

# --- dev.liquidarc.app only (not used on main) ---
# Email (Resend) — set on dev branch to enable transactional emails
RESEND_API_KEY=re_...                      # Get from resend.com
EMAIL_FROM=LiquidArc <noreply@yourdomain.com>

# Stripe — set on dev branch with sandbox keys; move to main when prod-ready
STRIPE_SECRET_KEY=sk_test_...              # Get from dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... # Get from dashboard.stripe.com
STRIPE_WEBHOOK_SECRET=whsec_...           # Get from Stripe webhooks dashboard
STRIPE_PRO_PRICE_ID=price_...             # Created via Stripe API or dashboard
STRIPE_ENTERPRISE_PRICE_ID=price_...      # Created via Stripe API or dashboard
